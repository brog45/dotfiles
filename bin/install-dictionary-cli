#!/bin/bash

set -ex


sudo apt-get install sdcv

sudo mkdir -p /usr/share/stardict/dic/

curl -O https://web.archive.org/web/20140917131745/http://abloz.com/huzheng/stardict-dic/dict.org/stardict-dictd_www.dict.org_gcide-2.4.2.tar.bz2

sudo tar -xvjf stardict-dictd_www.dict.org_gcide-2.4.2.tar.bz2 -C /usr/share/stardict/dic

curl -O https://foldoc.org/foldoc.tar.gz

sudo tar -xvzf foldoc.tar.gz -C /usr/share/stardict/dic

curl -O http://abloz.com/huzheng/stardict-dic/misc/stardict-xfardic-gnu-linux-2.4.2.tar.bz2

sudo tar -xvjf stardict-xfardic-gnu-linux-2.4.2.tar.bz2 -C /usr/share/stardict/dic

